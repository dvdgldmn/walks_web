POSTGRES_DB=dostywalks
POSTGRES_USER=dostywalks
POSTGRES_PASSWORD=replace-with-local-postgres-password
POSTGRES_PORT=5432

DATABASE_URL=postgresql://dostywalks:replace-with-local-postgres-password@localhost:5432/dostywalks?schema=public

API_PORT=4000
API_BASE_URL=http://localhost:4000
JWT_ACCESS_SECRET=replace-with-local-access-secret
JWT_REFRESH_SECRET=replace-with-local-refresh-secret
JWT_ACCESS_EXPIRES=8h
ADMIN_EMAIL=admin@dosty.local
ADMIN_PASSWORD=replace-with-local-admin-password

ADMIN_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:4000

WEBSITE_PORT=3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

UPLOADS_DIR=../../uploads

CONTACT_SMTP_HOST=smtp.example.com
CONTACT_SMTP_PORT=587
CONTACT_SMTP_SECURE=false
CONTACT_SMTP_USER=no-reply@example.com
CONTACT_SMTP_PASS=replace-with-local-smtp-password
CONTACT_FROM_EMAIL=no-reply@example.com
CONTACT_TO_EMAIL=hello@example.com
