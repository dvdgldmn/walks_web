{
  "name": "dostywalks-platform",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:api": "npm --workspace apps/api run start:dev",
    "dev:admin": "npm --workspace apps/admin run dev",
    "dev:website": "npm --workspace apps/website run dev",
    "build:api": "npm --workspace apps/api run build",
    "build:admin": "npm --workspace apps/admin run build",
    "build:website": "npm --workspace apps/website run build",
    "prisma:generate": "npm --workspace apps/api run prisma:generate",
    "prisma:migrate": "npm --workspace apps/api run prisma:migrate",
    "prisma:seed": "npm --workspace apps/api run prisma:seed"
  }
}
