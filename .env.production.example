POSTGRES_DB=dostywalks
POSTGRES_USER=dostywalks
POSTGRES_PASSWORD=replace-with-strong-postgres-password
POSTGRES_INITDB_ARGS=--encoding=UTF8 --locale=C.UTF-8
POSTGRES_PORT=5432

DATABASE_URL=postgresql://dostywalks:replace-with-strong-postgres-password@postgres:5432/dostywalks?schema=public

API_PORT=4000
API_BASE_URL=https://api.example.com
JWT_ACCESS_SECRET=replace-with-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-long-random-refresh-secret
JWT_ACCESS_EXPIRES=8h
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-strong-admin-password

ADMIN_PORT=3001
NEXT_PUBLIC_API_URL=https://api.example.com
INTERNAL_API_URL=http://api:4000

WEBSITE_PORT=3000
# Optional host port overrides (defaults match the in-container ports).
# Use these if 3000/3001/4000 are taken on the host by another tenant.
# WEBSITE_HOST_PORT=3000
# ADMIN_HOST_PORT=3001
# API_HOST_PORT=4000
NEXT_PUBLIC_SITE_URL=https://example.com

# CORS allowlist for the API (comma-separated). Defaults to localhost:3000/3001 if unset.
CORS_ORIGINS=https://example.com,https://admin.example.com

UPLOADS_DIR=../../uploads

# Contact form delivers via Zoho Mail HTTP API.
# Get client_id + client_secret from https://api-console.zoho.com/ (Self Client).
# Exchange a one-time `code` (Generate Code tab) for a refresh_token via
#   curl -X POST https://accounts.zoho.com/oauth/v2/token \
#        -d code=... -d client_id=... -d client_secret=... -d grant_type=authorization_code
# Get account_id with: GET https://mail.zoho.com/api/accounts (Authorization: Zoho-oauthtoken <access_token>).
ZOHO_OAUTH_CLIENT_ID=replace-with-zoho-self-client-id
ZOHO_OAUTH_CLIENT_SECRET=replace-with-zoho-self-client-secret
ZOHO_OAUTH_REFRESH_TOKEN=replace-with-zoho-refresh-token
ZOHO_MAIL_ACCOUNT_ID=replace-with-zoho-mail-account-id
CONTACT_FROM_EMAIL=hello@example.com
CONTACT_TO_EMAIL=hello@example.com
